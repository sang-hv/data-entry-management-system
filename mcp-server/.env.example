# Phải match DATABASE_URL trong .env.local của app chính
DATABASE_URL=postgresql://dems:dems_dev_password@localhost:5432/dems

# UUID cố định của AI actor user (đã set sẵn trong prisma/seed.ts)
AI_ACTOR_ID=00000000-0000-4000-a000-000000000a1c

# MCP Inspector — token cố định để không phải copy URL mỗi lần test local
# (không cần thiết ở môi trường prod/OpenClaw)
MCP_PROXY_AUTH_TOKEN=dems-local-dev
