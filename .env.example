# Database
DATABASE_URL="postgresql://dems:dems_dev_password@localhost:5432/dems?schema=public"

# App
NODE_ENV=development
LOG_LEVEL=info
SESSION_TTL_DAYS=7

# Storage
STORAGE_DIR=./storage/uploads

# Seed admin (chỉ dùng cho seed)
SEED_ADMIN_EMAIL=admin@local
SEED_ADMIN_NAME=Administrator
# Password cố định cho admin. Nếu đặt, mỗi lần `pnpm seed` chạy sẽ
# cập nhật password admin về giá trị này (dùng để recover khi quên,
# hoặc khi tests wipe DB). Nếu để trống, seed sẽ sinh password ngẫu
# nhiên và in ra console (chỉ áp dụng cho lần tạo đầu).
# Yêu cầu: ≥10 ký tự, có ≥1 chữ + ≥1 số.
SEED_ADMIN_PASSWORD=Admin@Local2026

# MCP Server — AI Actor UUID (cố định, set sẵn trong seed)
AI_ACTOR_ID=00000000-0000-4000-a000-000000000a1c
